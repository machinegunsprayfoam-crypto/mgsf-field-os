# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and anon key from https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Used by /api/ai for estimate parsing, takeoff, and ROI analysis
ANTHROPIC_API_KEY=sk-ant-...

# ── HubSpot ───────────────────────────────────────────────────────────────────
# Private app token from https://app.hubspot.com → Settings → Integrations → Private apps
HUBSPOT_TOKEN=pat-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_... # or sk_test_... for development

# ── Google Drive ──────────────────────────────────────────────────────────────
# Used by /api/drive to auto-create job folder structures
# Service account credentials JSON (full JSON string, stringified)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Google Drive parent folder ID where job folders will be created
GOOGLE_DRIVE_PARENT_ID=<folder-id-from-drive-url>
