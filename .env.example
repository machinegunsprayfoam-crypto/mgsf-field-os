# ──────────────────────────────────────────────────────────────────────────────
# MGSF Field OS — Environment Variables
# Copy to .env.local for local development. Set each variable in:
#   Vercel → mgsf-fieldos → Settings → Environment Variables
#
# Variables marked (required) must be set for that feature to work.
# Variables marked (optional) enable extra features but the app runs without them.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# (required) Your Supabase project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# (required) Service-role key — server-side only, bypasses Row Level Security.
# Never expose this to the browser or commit it to git.
SUPABASE_SERVICE_KEY=******

# ── Anthropic (Klyfton AI) ────────────────────────────────────────────────────
# (required for AI features) Found at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# (optional) If set, the Klyfton chat requires the crew to enter this code.
# Protects the AI from unauthorized use. Any string you choose.
CREW_CODE=your-crew-passphrase

# ── HubSpot CRM ───────────────────────────────────────────────────────────────
# (optional) Private-app token — enables the Call List and contact log features.
# Create at: HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_TOKEN=pat-na1-...

# ── Stripe (Deposit Links) ────────────────────────────────────────────────────
# (optional) Secret key — enables generating Stripe Checkout deposit links.
# Found at: https://dashboard.stripe.com/apikeys
# Use the test key (sk_test_...) until you are ready for live payments.
STRIPE_SECRET_KEY=sk_live_...

# ── Alerts & Notifications ────────────────────────────────────────────────────
# (optional) Webhook URL (Zapier Catch Hook, Make, Twilio Flow, etc.).
# All alert APIs (notify, funnel-remind, asset-alert) POST to this URL.
# Set it once and every alert type uses it automatically.
ALERTS_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxxxx/xxxxxxx/

# (optional) If set, POST requests to /api/funnel-remind must include this value
# in the Authorization header. Vercel Cron sets Authorization: ******
# automatically — set FUNNEL_REMIND_SECRET to the same value as CRON_SECRET.
FUNNEL_REMIND_SECRET=

# ── Vercel Cron (shared secret) ───────────────────────────────────────────────
# (optional) Vercel injects this as the ****** on all cron-triggered requests.
# Set it to a long random string, then set FUNNEL_REMIND_SECRET to the same value.
# Generate one with: openssl rand -hex 32
CRON_SECRET=

# ── Vercel KV / Upstash Redis (multi-device sync & photos) ───────────────────
# (optional) Auto-injected by Vercel when you attach a KV (Upstash) store.
# You can also set them manually if using an external Upstash instance.
KV_REST_API_URL=https://xxxxxxxx.upstash.io
KV_REST_API_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Drive (job folder creation) ───────────────────────────────────────
# (optional) Enables /api/drive to create job folders in Google Drive.
# GOOGLE_SERVICE_ACCOUNT_JSON: the full JSON credentials for a service account
#   that has "Editor" access to your target Drive folder.
#   Paste the entire JSON as a single line (or use a base64-encoded string).
# GOOGLE_DRIVE_PARENT_ID: the folder ID where new job folders will be created.
#   Get it from the URL: drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_DRIVE_PARENT_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ
